# SysEdge uses its OWN Neo4j on port 7688, separate from your application Neo4j.
# This prevents test teardowns or application operations from touching the graph.
# Copy to .env in your project root (NOT inside this setup/ directory).

# Used by sys_graph_viz.py (web visualiser)
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=sysedge

# Used by sys_graph.py (CLI)
SYSGRAPH_NEO4J_URI=bolt://localhost:7688
SYSGRAPH_NEO4J_USER=neo4j
SYSGRAPH_NEO4J_PASSWORD=sysedge
